# Server Configuration
PORT=4001
ZONA_HORARIA="Es"

# Database
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here-change-this-in-production"

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Admin Credentials (for seeding)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# File Paths
IMAGES_PATH="/var/www/admin-perfumeria/uploads/"

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Email Configuration (Nodemailer / Hostinger)
# Hostinger recomendado: puerto 465 con SSL. Si tu entorno bloquea 465, usa 587 y SMTP_SECURE=false.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="ventas@tudominio.com"
SMTP_PASS="mailbox-password"
EMAIL_FROM="DIFIORI <ventas@tudominio.com>"

# Alias compatibles con código legacy. Mantener igual que SMTP_* si se usan.
EMAIL_HOST="smtp.hostinger.com"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="ventas@tudominio.com"
EMAIL_PASS="mailbox-password"

# Company Information (for invoices)
COMPANY_NAME="Your Company Name"
COMPANY_EMAIL="info@example.com"
COMPANY_PHONE="+1 (555) 123-4567"
COMPANY_ADDRESS="123 Main St, City, State 12345"

# ============================================
# NOTA PARA DESPLIEGUE CON TRAEFIK:
# ============================================
# Asegúrate de tener configurados en GitHub Secrets:
# - DATABASE_URL
# - JWT_SECRET
# - STRIPE_PUBLISHABLE_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
# - ADMIN_EMAIL, ADMIN_PASSWORD
# - IMAGES_PATH
# - CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
# - CORS_ORIGIN
# - SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, SMTP_PASS, EMAIL_FROM
# - COMPANY_NAME, COMPANY_EMAIL, COMPANY_PHONE, COMPANY_ADDRESS

# Internal notifications
OWNER_NOTIFICATION_NAME="Sales Team"
OWNER_NOTIFICATION_EMAIL="ventas@example.com"

# Payment Providers - Default Active Environment
PAYPAL_ENVIRONMENT="sandbox"
PAYPHONE_ENVIRONMENT="sandbox"

# PayPal Sandbox / Development
PAYPAL_SANDBOX_CLIENT_ID="paypal-sandbox-client-id"
PAYPAL_SANDBOX_CLIENT_SECRET="paypal-sandbox-client-secret"
PAYPAL_SANDBOX_MERCHANT_ID="paypal-sandbox-merchant-id"
PAYPAL_SANDBOX_WEBHOOK_ID="paypal-sandbox-webhook-id"

# PayPal Live / Production
PAYPAL_LIVE_CLIENT_ID="paypal-live-client-id"
PAYPAL_LIVE_CLIENT_SECRET="paypal-live-client-secret"
PAYPAL_LIVE_MERCHANT_ID="paypal-live-merchant-id"
PAYPAL_LIVE_WEBHOOK_ID="paypal-live-webhook-id"

# PayPhone Sandbox / Development
PAYPHONE_SANDBOX_STORE_ID="payphone-sandbox-store-id"
PAYPHONE_SANDBOX_TOKEN="payphone-sandbox-token"
PAYPHONE_SANDBOX_WEBHOOK_TOKEN="payphone-sandbox-webhook-token"

# PayPhone Live / Production
PAYPHONE_LIVE_STORE_ID="payphone-live-store-id"
PAYPHONE_LIVE_TOKEN="payphone-live-token"
PAYPHONE_LIVE_WEBHOOK_TOKEN="payphone-live-webhook-token"
