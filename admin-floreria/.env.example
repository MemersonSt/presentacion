# ==============================================
# CONFIGURACION DE BASE DE DATOS
# ==============================================
POSTGRES_USER=perfumeria_user
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=dbfloreria

# ==============================================
# CONFIGURACION DEL PROYECTO
# ==============================================

# --- Web Perfume (Next.js) ---
ECOMMERCE_API_URL=http://ecommerce-be:3001
ADMIN_API_URL=http://api-perfumeria:3001
NEXT_PUBLIC_API_URL=https://ecommerce-api.perfumeriasz.com
PAYPHONE_TOKEN=your_payphone_token_here
PAYPHONE_ENVIRONMENT=sandbox
PAYPHONE_SANDBOX_STORE_ID=your_payphone_sandbox_store_id
PAYPHONE_SANDBOX_TOKEN=your_payphone_sandbox_token
PAYPHONE_SANDBOX_WEBHOOK_TOKEN=your_payphone_sandbox_webhook_token
PAYPHONE_LIVE_STORE_ID=your_payphone_live_store_id
PAYPHONE_LIVE_TOKEN=your_payphone_live_token
PAYPHONE_LIVE_WEBHOOK_TOKEN=your_payphone_live_webhook_token
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_SANDBOX_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_SANDBOX_CLIENT_SECRET=your_paypal_sandbox_client_secret
PAYPAL_SANDBOX_MERCHANT_ID=your_paypal_sandbox_merchant_id
PAYPAL_SANDBOX_WEBHOOK_ID=your_paypal_sandbox_webhook_id
PAYPAL_LIVE_CLIENT_ID=your_paypal_live_client_id
PAYPAL_LIVE_CLIENT_SECRET=your_paypal_live_client_secret
PAYPAL_LIVE_MERCHANT_ID=your_paypal_live_merchant_id
PAYPAL_LIVE_WEBHOOK_ID=your_paypal_live_webhook_id
DATABASE_URL=postgresql://perfumeria_user:change_this_password_in_production@postgres:5432/perfumeria_db?schema=public

# --- Ecommerce Backend (NestJS) ---
# DATABASE_URL se configurara automaticamente en docker-compose
NODE_ENV=production
PORT=3001

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
COMPANY_EMAIL=ventas@tudominio.com
OWNER_NOTIFICATION_NAME=Equipo Comercial
OWNER_NOTIFICATION_EMAIL=ventas@tudominio.com

# --- API Admin (Node/Express) ---
# DATABASE_URL se configurara automaticamente en docker-compose
JWT_SECRET=change_this_jwt_secret_in_production_min_32_chars
SESSION_SECRET=change_this_session_secret_in_production
API_KEY=your_api_key_here

# ==============================================
# CONFIGURACION DE PRODUCCION
# ==============================================
# Asegurate de cambiar todas las contrase˝as y secretos
# antes de desplegar en produccion
