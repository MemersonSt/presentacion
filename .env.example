DATABASE_URL=postgresql://user:password@localhost:5432/furniture_db
PORT=3000
BACKEND_URL=http://localhost:4001
APP_PUBLIC_SITE_URL=http://localhost:3000
# Opcional: si imagenes/uploads salen desde otro dominio o CDN
# APP_PUBLIC_ASSET_URL=https://cdn.tu-dominio.com

# Pasarelas de pago visibles por entorno
PAYPAL_ENVIRONMENT=sandbox
PAYPHONE_ENVIRONMENT=sandbox
PAYPAL_SANDBOX_CLIENT_ID=your_paypal_sandbox_client_id
PAYPAL_LIVE_CLIENT_ID=your_paypal_live_client_id
PAYPHONE_SANDBOX_STORE_ID=your_payphone_sandbox_store_id
PAYPHONE_LIVE_STORE_ID=your_payphone_live_store_id

# NODE_ENV=development
# SESSION_SECRET=your_secret_here

# Compatibilidad heredada:
# SITE_URL y VITE_SITE_URL siguen funcionando, pero APP_PUBLIC_SITE_URL es el nombre recomendado.
# ASSET_BASE_URL y VITE_ASSET_BASE_URL siguen funcionando, pero APP_PUBLIC_ASSET_URL es el nombre recomendado.
